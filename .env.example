# Nevertwice configuration — copy to `.env` (gitignored) and fill in.
# Everything is optional: with no cloud key and no Ollama, extraction simply
# pauses; recall still works on whatever is already stored.
#
# This file lists ONLY the handful most people might touch. The full reference —
# all 98 tunables, grouped — is in docs/CONFIG.md. You almost certainly need none
# of them: `python install.py` auto-detects a backend and prints what it chose.

# ── Cloud extraction backend (fast, off-GPU). Pick ONE; falls back to Ollama. ──
# cerebras (default) | groq | deepseek | gemini | none
NEVERTWICE_CLOUD=cerebras
CEREBRAS_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# ── Paths (sensible cross-platform defaults; override only if needed) ──
# Memory store (markdown + git). Default: ~/.nevertwice
# NEVERTWICE_HOME=~/.nevertwice
# Host-agent transcript dir for the catch-up sweep. Default: ~/.claude/projects
# NEVERTWICE_PROJECTS_ROOT=

# Also treat everything under these roots as projects (comma/os.pathsep list).
# Empty by default — any git repository you work in is tracked automatically.
# NEVERTWICE_PROJECT_ROOTS=

# ── Embedding backend (for semantic recall). Default: local Ollama (bge-m3). ──
# Set a cloud provider to get semantic recall with NO local model — one API key.
# ollama (default) | openai | voyage | cohere | gemini
# NEVERTWICE_EMBED_PROVIDER=ollama
# NEVERTWICE_EMBED_MODEL=               # provider default if unset (e.g. text-embedding-3-small)
# OPENAI_API_KEY=                      # for NEVERTWICE_EMBED_PROVIDER=openai
# VOYAGE_API_KEY=                      # for voyage
# COHERE_API_KEY=                      # for cohere
# (gemini reuses GEMINI_API_KEY above)
# NEVERTWICE_EMBED_BASE_URL=            # any OpenAI-compatible /v1/embeddings host (together/deepinfra/localai)
# After switching provider/model, re-embed once: python nevertwice/embed_index.py --rebuild
#   (the cache self-invalidates — recall stays on lexical until the rebuild, never wrong).

# ── Local models (Ollama) — values shown are the defaults ──
# OLLAMA_URL=http://127.0.0.1:11434/api/generate
# NEVERTWICE_EMBED_MODEL=bge-m3
# NEVERTWICE_MODEL=qwen3:8b

# ── Scaling (defaults shown) ──
# NEVERTWICE_PREFILTER_LIMIT=600        # past this many candidates, FTS-prefilter then
#                                      # cosine-rerank the top — bounds per-prompt cost
# NEVERTWICE_MAX_LIVE_PER_PROJECT=0     # 0=off; >0 archives lowest-salience excess per project

# ── Behaviour toggles (defaults shown) ──
# NEVERTWICE_PROMPT_RECALL=1          # task-aware recall on every prompt
# NEVERTWICE_PROMPT_RECALL_MODE=smart # smart | once | every
# NEVERTWICE_RERANK=0                 # cloud-judge rerank for on-demand search
# NEVERTWICE_GIT_PUSH=0               # push the store to a remote after each commit
